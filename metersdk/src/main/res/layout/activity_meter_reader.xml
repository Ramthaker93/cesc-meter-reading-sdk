<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1565C0"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Meter Reader"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/mr_tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SDK v1.0"
                android:textColor="#BBDEFB"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- USB STATUS -->
        <TextView
            android:id="@+id/mr_tvUsbStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USB: Checking..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:gravity="center"
            android:background="#1565C0"
            android:layout_marginBottom="10dp"/>

        <!-- CONFIG CARD (hidden when extras pre-set make+mode) -->
        <LinearLayout
            android:id="@+id/mr_configCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Meter Make"
                android:textColor="#1565C0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/mr_spinnerMeterMake"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#E3F2FD"
                android:paddingLeft="10dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reading Mode"
                android:textColor="#1565C0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/mr_spinnerReadMode"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#E3F2FD"
                android:paddingLeft="10dp"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>

        <!-- PRE-SET BADGE (shown instead of config card when intent extras lock make+mode) -->
        <LinearLayout
            android:id="@+id/mr_badgeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:elevation="2dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/mr_tvBadge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1565C0"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- REFRESH USB -->
        <Button
            android:id="@+id/mr_btnRefreshUsb"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="REFRESH USB STATUS"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:layout_marginBottom="6dp"
            android:elevation="2dp"/>

        <!-- START + ABORT BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <Button
                android:id="@+id/mr_btnStart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:text="START READING"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="#1565C0"
                android:layout_marginEnd="8dp"
                android:elevation="4dp"/>
            <Button
                android:id="@+id/mr_btnAbort"
                android:layout_width="100dp"
                android:layout_height="60dp"
                android:text="ABORT"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="#C62828"
                android:enabled="false"
                android:elevation="4dp"/>
        </LinearLayout>

        <!-- STATUS LINE -->
        <TextView
            android:id="@+id/mr_tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready — connect USB optical cable and press Start."
            android:textColor="#1565C0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="6dp"
            android:elevation="2dp"/>

        <!-- PROGRESS BAR -->
        <ProgressBar
            android:id="@+id/mr_progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#1565C0"
            android:progressBackgroundTint="#BBDEFB"
            android:layout_marginBottom="8dp"/>

        <!-- RESULT CARD -->
        <LinearLayout
            android:id="@+id/mr_resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:elevation="2dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/mr_tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1B5E20"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>
            <Button
                android:id="@+id/mr_btnDone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="DONE — RETURN TO APP"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#2E7D32"
                android:elevation="2dp"/>
        </LinearLayout>

        <!-- ACTIVITY LOG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Activity Log"
                    android:textColor="#1565C0"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <Button
                    android:id="@+id/mr_btnClearLog"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Clear"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:background="#E3F2FD"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"/>
            </LinearLayout>
            <ScrollView
                android:id="@+id/mr_scrollLog"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="#F5F9FF"
                android:padding="6dp">
                <TextView
                    android:id="@+id/mr_tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#212121"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:text=""/>
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

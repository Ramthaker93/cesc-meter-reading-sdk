<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/common_google_signin_btn_text_dark_disabled"
    android:padding="16dp">
    <EditText
        android:id="@+id/txtuser"
        android:layout_width="346dp"
        android:layout_height="wrap_content"
        android:editable="false"
        android:ems="10"
        android:enabled="false"
        android:inputType="textPersonName"
        android:paddingTop="5dp"
        android:textSize="25sp"
        android:text="Login : sandeep"
        android:textColor="#FF5733"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:paddingTop="50dp"  >

        <Button
            android:id="@+id/btnsearch"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:background="#e6b629"
            android:onClick="onbtnsearch"
            android:paddingBottom="10dp"
            android:paddingLeft="16dp"
            android:textSize="32sp"
            android:paddingRight="15dp"
            android:paddingTop="10dp"
            android:text="Search"
            android:textColor="#ffffff"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingTop="50dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnDatasync"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:background="#e6b629"
            android:onClick="onbtnDatasync"
            android:paddingBottom="10dp"
            android:paddingLeft="15dp"
            android:textSize="32sp"
            android:paddingRight="15dp"
            android:paddingTop="10dp"
            android:text="Data Sync"
            android:textColor="#ffffff"
            android:textStyle="bold" />
    </LinearLayout>





    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingTop="50dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnpayment"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:background="#e6b629"
            android:onClick="onbtnpayment"
            android:paddingLeft="15dp"
            android:paddingTop="10dp"
            android:paddingRight="15dp"
            android:paddingBottom="10dp"
            android:text="Payment"
            android:textColor="#ffffff"
            android:textSize="33sp"
            android:textStyle="bold" />



    </LinearLayout>


    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingTop="50dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnReport"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:background="#e6b629"
            android:onClick="onbtnReport"
            android:paddingLeft="15dp"
            android:paddingTop="10dp"
            android:paddingRight="15dp"
            android:paddingBottom="10dp"
            android:text="Report"
            android:textColor="#ffffff"
            android:textSize="33sp"
            android:textStyle="bold" />



    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingTop="50dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnaddhocreading"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:background="#e6b629"
            android:onClick="onbtnaddhocreading"
            android:paddingLeft="15dp"
            android:paddingTop="10dp"
            android:paddingRight="15dp"
            android:paddingBottom="10dp"
            android:text="Ad hoc Reading"
            android:textColor="#ffffff"
            android:textSize="33sp"
            android:textStyle="bold" />



    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingTop="50dp"
        android:orientation="horizontal">


    </LinearLayout>
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingTop="50dp"
        android:visibility="invisible"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnMReading"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:background="#e6b629"
            android:onClick="onbtnMReading"
            android:paddingLeft="15dp"
            android:paddingTop="10dp"
            android:paddingRight="15dp"
            android:paddingBottom="10dp"
            android:text="DownLoad Meter"
            android:textColor="#ffffff"
            android:textSize="33sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

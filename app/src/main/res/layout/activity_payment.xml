<?xml version="1.0" encoding="utf-8"?>

<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tableLayout1"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent" >

    <!-- 2 columns -->
    <TableRow
        android:id="@+id/tableRow0"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >
        <EditText
            android:id="@+id/txtuser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#87CEEB"
            android:layout_span="2"
            android:editable="false"
            android:enabled="false"
            android:textStyle="bold"
            android:textColor="#FF5733"
            android:ems="10"
            android:inputType="textPersonName"
            android:paddingTop="1dp"
            android:text="Login : sandeep" />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >


        <RadioButton
            android:id="@+id/rbConsNo"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="Consumer No"
            android:layout_marginRight="10px"
            android:textSize="10sp"
            />/>

        <RadioButton
            android:id="@+id/rbMeterNo"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="Meter No"
            android:textSize="10sp"
            />

    </TableRow>
    <TableRow
        android:id="@+id/tableRow2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >

        <EditText
            android:id="@+id/txtConsumerNo"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignEnd="@+id/editText2"
            android:layout_below="@+id/imageView"
            android:layout_marginTop="1dp"
            android:focusable="true"
            android:hint=""
            android:textSize="10sp"
            android:textColor="#000000"
            android:textColorHighlight="#ff7eff15"
            android:textColorHint="#ffff25e6" />

        <Button
            android:id="@+id/btnShow"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_alignBaseline="@+id/button2"
            android:layout_alignBottom="@+id/button2"
            android:layout_toStartOf="@+id/textview"
            android:onClick="onShowButtonClicked"
            android:text="Show"
            android:textSize="10sp" />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >

        <TextView
            android:id="@+id/lbtConsumerNo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Consumer No" />
        <TextView
            android:id="@+id/lbConsumerNo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="" />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dip" >

        <TextView
            android:id="@+id/lbtMeterNo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Meter No" />
        <TextView
            android:id="@+id/lbMeterNo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="" />

        <TextView android:id="@+id/hidden_KWH"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dip" >

        <TextView
            android:id="@+id/lbtName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Name" />
        <TextView
            android:id="@+id/lbName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="" />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >

        <TextView
            android:id="@+id/lbtAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Address" />
        <TextView
            android:id="@+id/lbAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="false"
            android:text="" />
    </TableRow>

    <TableRow
        android:id="@+id/tableRow20"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >

        <TextView
            android:id="@+id/lbtBillmonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Bill Month" />
        <TextView
            android:id="@+id/lbBillMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="false"
            android:text="" />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >

        <TextView
            android:id="@+id/lbtlasPaidAmt"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="Last Paid Amount"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/lblastPaidAmt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="false"
            android:text="" />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >

        <TextView
            android:id="@+id/lbtArrear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Arrear" />
        <TextView
            android:id="@+id/lblArrear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="false"
            android:text="" />
    </TableRow>

    <TableRow
        android:id="@+id/tableRow9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >

        <TextView
            android:id="@+id/lbtCurrBillAmt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Current Billed Amount" />
        <TextView
            android:id="@+id/lblCurrBillAmt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="false"
            android:text="" />
        <TextView android:id="@+id/hidden_ConsAc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="hidden value"
            android:visibility="gone"/>
    </TableRow>

    <TableRow
        android:id="@+id/tableRow10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="1dip" >

        <TextView
            android:id="@+id/lbtPayAmt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Payable Amount (As on date)" />
        <TextView
            android:id="@+id/lblPayable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="false"
            android:text="" />
    </TableRow>

    <TableRow
        android:id="@+id/tableRow11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dip" >
        <EditText
            android:id="@+id/txtMobileno"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignEnd="@+id/editText2"
            android:layout_below="@+id/imageView"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:focusable="true"
            android:maxLength="10"
            android:hint="Mobile No"
            android:inputType="number"
            android:textColor="#000000"
            android:textColorHighlight="#ff7eff15"
            android:textColorHint="#ffff25e6" />
        <EditText
            android:id="@+id/txtPayAmt"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignEnd="@+id/editText2"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:focusable="true"
            android:hint="Amount To be Paid"
            android:inputType="number"
            android:textColor="#000000"
            android:textColorHighlight="#ff7eff15"
            android:textColorHint="#ffff25e6" />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dip" >
        <Spinner
            android:id="@+id/ddlPayMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_span="2"
            android:layout_marginTop="2dp" />
    </TableRow>
    <TableRow
        android:id="@+id/tableRow13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dip" >
        <EditText
            android:id="@+id/txtChequeNo"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignEnd="@+id/editText2"
            android:layout_below="@+id/imageView"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:focusable="true"
            android:hint="Cheque No"
            android:inputType="number"
            android:textColor="#000000"
            android:textColorHighlight="#ff7eff15"
            android:textColorHint="#ffff25e6" />
        <EditText
            android:id="@+id/txtChequeDate"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignEnd="@+id/editText2"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:focusable="true"
            android:hint="Cheque Date"
            android:inputType="number"
            android:textColor="#000000"
            android:textColorHighlight="#ff7eff15"
            android:textColorHint="#ffff25e6" />
    </TableRow>

    <TableRow
        android:id="@+id/tableRow14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dip" >
        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:onClick="onbtnSaveClicked"
            >
        </Button>
        <Button
            android:id="@+id/btnGenQR"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Genrate QR"
            android:onClick="onbtnGenerateQR"
            >
        </Button>

        <Button
            android:id="@+id/btnPrint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Print"
            android:enabled="false"
            android:onClick="onbtnPrintClicked"
            android:visibility="gone"
            >
        </Button>
    </TableRow>
    <Button
        android:id="@+id/btnRefresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Refresh"
        >
    </Button>
    <ImageView
        android:id="@+id/qr_image"
        android:layout_width="wrap_content"
        android:layout_height="204dp"
        android:contentDescription="@string/app_name" />


    <EditText
        android:id="@+id/txtreceiptno"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_alignEnd="@+id/editText2"
        android:layout_marginTop="2dp"
        android:textSize="12sp"
        android:visibility="gone"
        />
</TableLayout>
